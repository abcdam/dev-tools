{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": ["@abcd/cfg/ts/base"],
  "compilerOptions": {
    "plugins": [
      { "transform": "typescript-transform-paths", "afterDeclarations": true }
    ],
    "rootDir": "src",
    "outDir": "dist",
    "declarationMap": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": {
      "#option/*": ["./src/modules/option/*"],
      "@branch:core/*": ["./src/modules/branch/core/*.js"],
      "#result/*": ["./src/modules/result/*"],
      "#utility/*": ["./src/modules/utility/*"],
      "#compose/*": ["./src/modules/compose/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
