{
  "$schema": "https://www.schemastore.org/tsconfig.json",
  "extends": ["@abcd/cfg/ts/base"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declarationMap": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "paths": {
      "#option/*": ["./src/modules/option/*"],
      "#branch/*": ["./src/modules/branch/*"],
      "#result/*": ["./src/modules/result/*"],
      "#utility/*": ["./src/modules/utility/*"],
      "#compose/*": ["./src/modules/compose/*"],
      "#intern/*": ["./src/internal/*.ts"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist", "src/generator"]
}
