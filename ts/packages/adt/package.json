{
  "$schema": "https://www.schemastore.org/package",
  "type": "module",
  "name": "@abcd/adt",
  "version": "0.4.0",
  "description": "",
  "imports": {
    "#result/*": "./src/modules/result/*",
    "#utility/*": "./src/modules/utility/*",
    "#option/*": "./src/modules/option/*",
    "#compose/*": "./src/modules/compose/*",
    "#branch/*": "./src/modules/branch/*"
  },
  "exports": {
    "./*": {
      "types": "./dist/exports/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationMap --rootDir src --outDir dist",
    "check": "tsc --noEmit",
    "lint": "biome check src",
    "fmt": "biome format --write src/modules",
    "gen": "tsx ./src/generator/index.ts && pnpm fmt",
    "prepack": "pnpm run build"
  },
  "files": [
    "dist",
    "LICENSE",
    "src"
  ],
  "devDependencies": {
    "@abcd/cfg": "workspace:*",
    "@biomejs/biome": "catalog:",
    "@types/node": "catalog:",
    "magic-string": "catalog:",
    "tsup": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  },
  "keywords": [],
  "author": "abcdam",
  "license": "MIT"
}
