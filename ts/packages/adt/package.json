{
  "$schema": "https://www.schemastore.org/package",
  "type": "module",
  "name": "@abcd/adt",
  "version": "0.1.0",
  "description": "",
  "exports": {
    "./*": {
      "types": "./dist/*/index.d.ts",
      "default": "./dist/*/index.js"
    }
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsup && tsc --emitDeclarationOnly --declarationMap --rootDir src/modules --outDir dist",
    "check": "tsc --noEmit",
    "lint": "biome check src"
  },
  "files": [
    "dist",
    "LICENSE",
    "src"
  ],
  "devDependencies": {
    "@abcd/cfg": "workspace:*",
    "@biomejs/biome": "catalog:",
    "ts-patch": "^3.3.0",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "typescript-transform-paths": "^3.5.6"
  },
  "keywords": [],
  "author": "abcdam",
  "license": "MIT"
}
